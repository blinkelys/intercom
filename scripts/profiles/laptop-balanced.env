# Laptop mic profile (balanced latency/accuracy)
# Source with: source ./scripts/profiles/laptop-balanced.env

export PROCOM_SENTENCE_MAX_WAIT_MS=2200
export PROCOM_SENTENCE_MIN_WORDS=9
export PROCOM_SENTENCE_MIN_PUNCT_WORDS=4
export PROCOM_AUDIO_MIN_RMS=0.010
export PROCOM_MIN_FINAL_CHARS=6

export PROCOM_MLX_NO_SPEECH_THRESHOLD=0.40
export PROCOM_MLX_LOGPROB_THRESHOLD=-0.65
export PROCOM_MLX_COMPRESSION_RATIO_THRESHOLD=2.1

# Keep language pinned per channel from app settings.
export PROCOM_MLX_TASK=transcribe
export PROCOM_MLX_TEMPERATURE=0
