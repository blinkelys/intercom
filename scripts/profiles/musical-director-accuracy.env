# Musical Director high-accuracy profile (quality over speed)
# Source with: source ./scripts/profiles/musical-director-accuracy.env

export PROCOM_SENTENCE_MAX_WAIT_MS=1700
export PROCOM_SENTENCE_MIN_WORDS=8
export PROCOM_SENTENCE_MIN_PUNCT_WORDS=4
export PROCOM_AUDIO_MIN_RMS=0.00002
export PROCOM_MIN_FINAL_CHARS=5

export PROCOM_MLX_MODEL=mlx-community/whisper-large-v3-turbo
export PROCOM_MLX_TASK=transcribe
export PROCOM_MLX_TEMPERATURE=0
export PROCOM_MLX_BEST_OF=3
export PROCOM_MLX_BEAM_SIZE=1
export PROCOM_MLX_CONDITION_ON_PREVIOUS_TEXT=true

export PROCOM_MLX_NO_SPEECH_THRESHOLD=0.45
export PROCOM_MLX_LOGPROB_THRESHOLD=-0.7
export PROCOM_MLX_COMPRESSION_RATIO_THRESHOLD=2.2
export PROCOM_MLX_PARTIAL_INTERVAL_SECONDS=1
export PROCOM_MLX_FINAL_WINDOW_SECONDS=5
export PROCOM_MLX_MAX_BUFFER_SECONDS=12

export PROCOM_MLX_TARGET_RMS=0.015
export PROCOM_MLX_MAX_GAIN=16
export PROCOM_MLX_RAW_RMS_FLOOR=0.00008
