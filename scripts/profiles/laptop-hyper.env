# Laptop mic profile (maximum stability over latency)
# Source with: source ./scripts/profiles/laptop-hyper.env

export PROCOM_SENTENCE_MAX_WAIT_MS=3000
export PROCOM_SENTENCE_MIN_WORDS=12
export PROCOM_SENTENCE_MIN_PUNCT_WORDS=6
export PROCOM_AUDIO_MIN_RMS=0.015
export PROCOM_MIN_FINAL_CHARS=8

export PROCOM_MLX_NO_SPEECH_THRESHOLD=0.35
export PROCOM_MLX_LOGPROB_THRESHOLD=-0.50
export PROCOM_MLX_COMPRESSION_RATIO_THRESHOLD=2.0

export PROCOM_MLX_TASK=transcribe
export PROCOM_MLX_TEMPERATURE=0
